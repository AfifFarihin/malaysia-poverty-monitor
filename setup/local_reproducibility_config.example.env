# Local reproducibility values for optional Earth Engine re-extraction.
# Copy this file to `.env` in the project root and replace values as needed.
# `.env` is ignored by Git; do not commit private credential paths or tokens.

# Final notebooks/dashboard can run from retained CSV artifacts without GEE.
GEE_EXTRACTION_ENABLED=false

# Required only when developing a separate optional Earth Engine extraction workflow.
EE_PROJECT_ID=your-google-cloud-project-id
EE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_APPLICATION_CREDENTIALS=
